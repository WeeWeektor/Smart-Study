# ==========================================
# Environment variables for Vite (React) project
# ==========================================

# === API Configuration ===
# Для локальної розробки використовуйте localhost (порт вашого бекенду)
VITE_API_BASE_URL=http://localhost:8000/api
VITE_API_URL=http://localhost:8000/api
VITE_APP_NAME=SmartStudy

# === OAuth Configuration (Social Auth) ===
# Google
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here
VITE_FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# === Cloud Storage (Supabase) ===
# Базовий шлях до публічного бакета із зображеннями для тестів
VITE_COURSE_QUESTION_IMAGE_PATH=https://your-project-id.supabase.co/storage/v1/object/public/